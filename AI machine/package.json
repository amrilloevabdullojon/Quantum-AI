{
  "name": "quantum-ai-wealth-guardian",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node server/local-api.mjs",
    "start": "node server/local-api.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "api": "node server/local-api.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "check": "npm run test && npm run build",
    "health": "node -e \"const url=process.env.HEALTH_URL||'http://127.0.0.1:8787/health'; fetch(url).then(async r=>{console.log(url, r.status, await r.text()); process.exit(r.ok?0:1);}).catch(e=>{console.error(e.message); process.exit(1);});\"",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "docker:config": "docker compose --env-file .env.production config",
    "docker:build": "docker compose build app",
    "docker:up": "docker compose --env-file .env.production up -d --build",
    "docker:down": "docker compose --env-file .env.production down",
    "docker:logs": "docker compose logs -f app",
    "deploy:check": "npm run check && npm run docker:config",
    "deploy:up": "npm run docker:up",
    "deploy:logs": "npm run docker:logs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
